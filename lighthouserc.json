{
  "ci": {
    "collect": {
      "numberOfRuns": 1
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["warn", { "minScore": 1 }],
            "categories:best-practices": ["warn", { "minScore": 1 }],
            "categories:performance": ["warn", { "minScore": 0.5 }],
            "categories:seo": ["warn", { "minScore": 1 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
