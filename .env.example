# Abolish Abortion Michigan — Environment Variables
# Copy to .env.local and fill in the values. See README.md for details.

# ============================================
# DATABASE (Neon Postgres)
# ============================================
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ============================================
# AUTHENTICATION (REQUIRED)
# ============================================

# Sign auth cookie + unsubscribe HMAC tokens. Must be >=32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Admin login email + bcrypt password hash + access code + high-impact PIN.
# Password hash: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
ADMIN_EMAIL=admin@abolishabortionmichigan.com
ADMIN_PASSWORD_HASH=
ADMIN_ACCESS_CODE=
ADMIN_PIN=

# ============================================
# EMAIL (Resend transactional API)
# ============================================
# From resend.com dashboard. Requires the sending domain to be verified.
RESEND_API_KEY=
# From address must be on the verified domain. Defaults to
# "Abolish Abortion Michigan <ADMIN_EMAIL>" if unset.
# RESEND_FROM=Abolish Abortion Michigan <noreply@abolishabortionmichigan.com>
# RESEND_FROM_NOTIFICATIONS=AAM Website <noreply@abolishabortionmichigan.com>
# Where admin notification emails land (petition, contact, subscribe alerts).
# Falls back to ADMIN_EMAIL.
# NOTIFICATION_EMAIL=

# ============================================
# RATE LIMITING (Upstash Redis REST)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# SITE
# ============================================
NEXT_PUBLIC_SITE_URL=https://abolishabortionmichigan.com

# ============================================
# OPTIONAL — Vercel preview CSRF allowance
# ============================================
# Set to your Vercel project slug (e.g. "abolish-abortion-michigan-website")
# so preview URLs <slug>-<branch>-<team>.vercel.app pass CSRF.
# Leave unset in local dev.
# VERCEL_PREVIEW_PROJECT_SLUG=

# ============================================
# OBSERVABILITY (PostHog + Sentry)
# ============================================
# PostHog project API key (product analytics + optional session replay).
# From posthog.com project settings.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry DSN — same DSN for browser and server; source-map upload uses the
# auth token in the second block. From sentry.io project settings.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=          # same value; used server-side if NEXT_PUBLIC_ isn't set
# SENTRY_ORG=          # e.g. "abolish-abortion-michigan"
# SENTRY_PROJECT=      # e.g. "aam-website"
# SENTRY_AUTH_TOKEN=   # for source-map uploads at build time (Vercel only)

# ============================================
# OPTIONAL — SEO
# ============================================
# Google Search Console verification code (drop the site-tag value here).
# NEXT_PUBLIC_GSC_VERIFICATION=
# Bing Webmaster Tools verification (msvalidate.01 content value).
# NEXT_PUBLIC_BING_VERIFICATION=

# ============================================
# NONPROFIT DISCLOSURE (required for Google Ad Grants approval)
# ============================================
# Federal Tax ID / EIN — 9 digits, no dashes. Add via CLI:
#   vercel env add NEXT_PUBLIC_ORG_EIN production --no-sensitive
# NEXT_PUBLIC_ORG_EIN=XX-XXXXXXX
# Public URL to the IRS Determination Letter (proof of 501(c)(3) status).
# Available from apps.irs.gov/pub/epostcard after IRS grants exemption.
# NEXT_PUBLIC_IRS_DETERMINATION_LETTER_URL=
# Public URL to the most recent IRS Form 990 (once filed).
# NEXT_PUBLIC_FORM_990_URL=
# Public URL to the annual report (once published).
# NEXT_PUBLIC_ANNUAL_REPORT_URL=

# ============================================
# OPTIONAL — Google Ad Grants
# ============================================
# Set these AFTER Ad Grants is activated and conversion actions are created
# in Google Ads UI. Add via CLI with `--no-sensitive` (they're client-side).
# Without them, the site runs normally and no gtag script loads.
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
# NEXT_PUBLIC_GOOGLE_ADS_CONV_PETITION=AW-XXXXXXXXX/aaaaaaaaaaa
# NEXT_PUBLIC_GOOGLE_ADS_CONV_INQUIRY=AW-XXXXXXXXX/bbbbbbbbbbb
# NEXT_PUBLIC_GOOGLE_ADS_CONV_NEWSLETTER=AW-XXXXXXXXX/ccccccccccc
# NEXT_PUBLIC_GOOGLE_ADS_CONV_DONATE=AW-XXXXXXXXX/ddddddddddd
